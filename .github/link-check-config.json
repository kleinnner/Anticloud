{
  "ignorePatterns": [
    {
      "pattern": "^http://localhost"
    },
    {
      "pattern": "^https://github.com/kleinnner/Anticloud/(issues|discussions|security)/"
    },
    {
      "pattern": "^https://github.com/kleinnner/Anticloud/blob/main"
    }
  ],
  "replacementPatterns": [
    {
      "pattern": "^/",
      "replacement": "https://github.com/kleinnner/Anticloud/blob/main/"
    }
  ],
  "timeout": "30s",
  "retryOn429": true,
  "retryCount": 3,
  "aliveStatusCodes": [200, 206, 301, 302, 307, 401, 403]
}
